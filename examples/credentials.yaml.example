default-context: prod
contexts:
  prod:
    url: https://jenkins.prod.example.com
    username: alice
    # Generate via Jenkins -> People -> alice -> Configure -> API Token.
    token: REPLACE_ME
  staging:
    url: https://jenkins.staging.example.com
    username: alice
    token: REPLACE_ME
    insecure: true  # lab clusters with self-signed certs only
